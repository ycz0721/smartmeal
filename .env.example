# === SmartMeal 环境变量 ===
# 复制此文件为 .env 并填入真实值

# 数据库 - 本地用 SQLite，部署用 PostgreSQL
# 本地：DATABASE_URL="file:./dev.db"
# 部署：DATABASE_URL="postgresql://user:pass@host:5432/smartmeal"
DATABASE_URL="postgresql://user:pass@host:5432/smartmeal"

# AI API Keys
DEEPSEEK_API_KEY="sk-xxxxxx"
ZHIPU_API_KEY="xxxxxx"

# 图片搜索（可选）
UNSPLASH_ACCESS_KEY="xxxxxx"

# NextAuth - 部署时务必改为真实域名
NEXTAUTH_SECRET="使用 openssl rand -base64 32 生成"
NEXTAUTH_URL="http://localhost:3000"
# 阿里云部署示例：NEXTAUTH_URL="https://smartmeal.your-domain.com"
