datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String         @id @default(cuid())
  phone        String         @unique
  password     String
  name         String?
  cuisines     String?
  intolerances String?
  dietary      String?
  familySize   Int            @default(2)
  mealPeople   String?
  isVip        Boolean        @default(false)
  vipExpireAt  DateTime?
  createdAt    DateTime       @default(now())
  recipes      Recipe[]
  plans        MealPlan[]
  pantry       PantryItem[]
  shopping     ShoppingItem[]
  ownedFamily  FamilySpace[]  @relation("FamilyOwner")
  familyMember FamilyMember[]
}

model Recipe {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  servings    Int      @default(4)
  cookTime    Int
  imageUrl    String?
  tags        String
  ingredients String
  steps       String
  source      String?
  favorite    Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MealPlan {
  id        String   @id @default(cuid())
  userId    String
  weekStart DateTime
  isCurrent Boolean  @default(false)
  meals         String
  cookedRecipes String @default("[]")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PantryItem {
  id     String @id @default(cuid())
  userId String
  name   String
  amount Float
  unit   String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, unit])
}

model ShoppingItem {
  id      String  @id @default(cuid())
  userId  String
  name    String
  amount  Float
  unit    String
  checked Boolean @default(false)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, unit])
}

model FamilySpace {
  id         String         @id @default(cuid())
  inviteCode String         @unique
  ownerId    String
  owner      User           @relation("FamilyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())
  members    FamilyMember[]
}

model FamilyMember {
  id       String      @id @default(cuid())
  spaceId   String
  space    FamilySpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId   String
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime    @default(now())

  @@unique([spaceId, userId])
}
